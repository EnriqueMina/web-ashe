---
/* Componente de Navegación con Logo */
---
<header class="site-header">
  <div class="header-container">
    <a href="/" class="logo-link">
      <img src="/images/logo.jpeg" alt="Logo ASHÉ" class="nav-logo" />
      <div class="logo-text">
        <span class="brand-name">ASHÉ</span>
        <span class="brand-sub">Medio Comunitario Afro</span>
      </div>
    </a>

    <nav class="main-navigation">
      <a href="/memoria">Memoria e Identidad</a>
      <a href="/comunidad">Comunidad y Territorio</a>
      <a href="/cultura">Cultura y Estética</a>
      <a href="/oportunidades">Oportunidades</a>
    </nav>
  </div>
</header>

<style>
  .site-header {
    background-color: #121111; /* Mantenemos el fondo oscuro premium */
    border-bottom: 1px solid rgba(196, 146, 77, 0.2); /* Línea dorada sutil */
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 1000;
    padding: 0.75rem 0;
  }

  .header-container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 2rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .logo-link {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .nav-logo {
    width: 50px; /* Tamaño elegante para la barra */
    height: 50px;
    border-radius: 50%; /* Asegura que el círculo sea perfecto */
    object-fit: cover;
    border: 2px solid var(--gold-accent, #C4924D); /* Anillo dorado sutil alrededor */
  }

  .logo-text {
    display: flex;
    flex-direction: column;
  }

  .brand-name {
    font-family: 'Prata', serif;
    font-size: 1.4rem;
    color: #FAF8F5;
    line-height: 1.1;
    letter-spacing: 0.05em;
  }

  .brand-sub {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 0.75rem;
    color: var(--gold-accent, #C4924D);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .main-navigation {
    display: flex;
    gap: 2rem;
  }

  .main-navigation a {
    font-family: 'Plus Jakarta Sans', sans-serif;
    color: #CECBC6;
    font-size: 0.9rem;
    font-weight: 500;
    letter-spacing: 0.02em;
  }

  .main-navigation a:hover {
    color: var(--gold-accent, #C4924D);
  }

  @media (max-width: 768px) {
    .header-container {
      flex-direction: column;
      gap: 1rem;
    }
    .main-navigation {
      gap: 1rem;
      flex-wrap: wrap;
      justify-content: center;
    }
  }
</style>