---
import LayoutBase from '../layouts/LayoutBase.astro';
---

<LayoutBase title="Inicio">
    <!-- Bloque de Bienvenida Principal -->
    <section class="hero-section">
        <h1 class="hero-title">"La Fuerza Cultural que mueve el Territorio"</h1>
        <p class="hero-description">
            Somos un medio comunitario afro que busca visibilizar las culturas, tradiciones, saberes y procesos organizativos de las comunidades negras, afrocolombianas, raizales y palenqueras presentes en Bogotá.
        </p>
    </section>

    <!-- Sección de Propósito Breve -->
    <section class="about-summary">
        <h2>Nuestro Propósito</h2>
        <p>
            Actuamos como un puente de comunicación, etnoeducación y relevo generacional, promoviendo el reconocimiento de las contribuciones afrodescendientes a la ciudad y fomentando la construcción colectiva desde principios como Ubuntu, la solidaridad y la memoria.
        </p>
    </section>
</LayoutBase>

<style>
    .hero-section {
        padding: 5rem 2rem;
        text-align: center;
        background-color: var(--negro-ebano);
        color: var(--marfil);
        border-bottom: 6px solid var(--dorado-ancestral);
    }

    .hero-title {
        font-size: 2.5rem;
        font-weight: 700;
        color: var(--dorado-ancestral);
        margin-bottom: 1.5rem;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .hero-description {
        font-size: 1.2rem;
        max-width: 800px;
        margin: 0 auto;
        line-height: 1.8;
    }

    .about-summary {
        padding: 4rem 2rem;
        max-width: 800px;
        margin: 0 auto;
        text-align: center;
    }

    .about-summary h2 {
        font-size: 2rem;
        color: var(--terracota-pacifico);
        margin-bottom: 1rem;
    }

    .about-summary p {
        font-size: 1.1rem;
        color: var(--negro-ebano);
        line-height: 1.7;
    }
</style>